import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

def f(x, alpha, beta):
    with np.errstate(all='ignore'):
        return (x ** beta + alpha ** beta) / x ** beta

# Построение общего графика функции
x = np.linspace(-5, 5, 501)
y1 = f(x, 1, 1)
y2 = f(x, 2, 1)
y3 = f(x, 1, 2)

fig = plt.figure(figsize=(8, 8))

plt.plot(x, y1, 'r', label='$\\alpha = 1, \\beta = 1$', linewidth=0.7)
plt.plot(x, y2, 'g', label='$\\alpha = 2, \\beta = 1$', linewidth=0.7)
plt.plot(x, y3, 'b', label='$\\alpha = 1, \\beta = 2$', linewidth=0.7)
plt.xlabel('x')
plt.ylabel('f(x)')
plt.title('График функции $f(x) = \\frac{x ^\\beta + \\alpha^\\beta}{x^\\beta}$ при различных $\\alpha$ и $\\beta$', fontsize=20)
plt.ylim(-15, 20)
plt.legend()
plt.savefig('E:\\new/1.1.svg')
plt.show()



