'''
Рассмотрим случайный вектор с формой (7,2), представляющей координаты. 
Найдите расстояния от точки до точки (результат представьте в виде матрицы - таким образом должна получиться матрица 5 на пять где элемент с индексом i и j будет растоянием между точкой i и j)
'''



import numpy as np
coord = np.random.randint(-5, 5, 14).reshape(7, 2)
print(coord)

X = coord[:, 0]
Y = coord[:, 1]
A = ([X] - X[:, np.newaxis]) ** 2
B = ([Y] - Y[:, np.newaxis]) ** 2
Z = np.sqrt(A + B).round(2)
print(Z)
