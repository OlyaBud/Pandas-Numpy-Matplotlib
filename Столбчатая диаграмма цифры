import pandas as pd, numpy as np
import matplotlib.pyplot as plt
from scipy import stats

from sklearn.datasets import load_digits

# Загрузка данных
digits = load_digits()
data = digits.data
target = digits.target
images = digits.images

print("Количество наблюдений:", data.shape[0])
print("Количество признаков:", data.shape[1])
print("Размер изображения:", images.shape[1], "x", images.shape[2])
print("Цифры в датасете:", np.unique(target))

unique, counts = np.unique(target, return_counts=True)
print("Цифры:", unique)
print("Количество:", counts)

# Распределение цифр в датасете
plt.bar(unique, counts)
plt.xlabel('Цифра')
plt.ylabel('Количество')
plt.title('Распределение цифр в датасете')
plt.grid(True, axis='y', alpha=0.3)
plt.xticks(np.arange(len(unique)))
plt.show()

# Средняя яркость изображений по цифрам
mean_brightness = [data[target == i].mean() for i in range(10)]

plt.bar(unique, mean_brightness)
plt.xlabel('Цифра')
plt.ylabel('Средняя яркость (0–16)')
plt.title('Средняя яркость изображений по цифрам')
plt.grid(True, axis='y', alpha=0.3)
plt.xticks(np.arange(len(unique)))
plt.show()
